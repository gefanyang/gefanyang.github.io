---
import type { Publication } from "../data/publications";

interface Props {
  publication: Publication;
}

const { publication } = Astro.props;
const titleHref = publication.pdf ?? publication.page ?? publication.code ?? "#";
---

<li class="publication-item">
  <div class="publication-title">
    <a href={titleHref} target={titleHref.startsWith("http") ? "_blank" : undefined} rel={titleHref.startsWith("http") ? "noopener noreferrer" : undefined}>
      {publication.title}
    </a>
  </div>
  <div class="publication-authors" set:html={publication.authorsHtml}></div>
  <div class="publication-venue">
    <em set:html={publication.conference}></em>
    {publication.conferenceShort && <abbr class="badge">{publication.conferenceShort}</abbr>}
  </div>
  <div class="publication-links">
    {publication.pdf && <a class="pub-button" href={publication.pdf} target="_blank" rel="noopener noreferrer">PDF</a>}
    {publication.code && <a class="pub-button" href={publication.code} target="_blank" rel="noopener noreferrer">Code</a>}
    {publication.page && <a class="pub-button" href={publication.page} target="_blank" rel="noopener noreferrer">Project Page</a>}
    {publication.bibtex && <a class="pub-button" href={publication.bibtex} target="_blank" rel="noopener noreferrer">BibTex</a>}
    {publication.notes && <strong class="publication-note"><i>{publication.notes}</i></strong>}
  </div>
</li>
