---
type IconName = "scholar" | "cv" | "github" | "linkedin";

interface Props {
  href: string;
  label: string;
  icon: IconName;
}

const { href, label, icon } = Astro.props;
---

<a class="social-icon" href={href} aria-label={label} title={label} target={href.startsWith("http") ? "_blank" : undefined} rel={href.startsWith("http") ? "noopener noreferrer" : undefined}>
  <svg viewBox="0 0 24 24" aria-hidden="true">
    {icon === "scholar" && (
      <>
        <path d="M12 3 1.8 11.2 12 19.4l10.2-8.2L12 3Zm0 3.1 5.9 4.7L12 15.5l-5.9-4.7L12 6.1Z" />
        <path d="M5.5 13.7V18c1.8 1.9 4 2.9 6.5 2.9s4.7-1 6.5-2.9v-4.3L12 18.9l-6.5-5.2Z" />
      </>
    )}
    {icon === "cv" && (
      <>
        <path d="M7 2.75h7.7L19 7.05v14.2H7V2.75Zm7 1.9v3.1h3.1L14 4.65Z" />
        <path d="M9.4 11.1h7.2v1.4H9.4v-1.4Zm0 3h7.2v1.4H9.4v-1.4Zm0 3h4.8v1.4H9.4v-1.4Z" />
      </>
    )}
    {icon === "github" && (
      <path d="M12 .9a11.1 11.1 0 0 0-3.5 21.6c.55.1.75-.24.75-.53v-2.05c-3.05.66-3.7-1.3-3.7-1.3-.5-1.27-1.22-1.6-1.22-1.6-1-.68.08-.67.08-.67 1.1.08 1.68 1.13 1.68 1.13.98 1.67 2.57 1.19 3.2.91.1-.71.38-1.19.69-1.47-2.43-.28-5-1.22-5-5.42 0-1.2.43-2.18 1.13-2.95-.11-.28-.49-1.4.11-2.91 0 0 .93-.3 3.05 1.13A10.5 10.5 0 0 1 12 6.38c.94 0 1.88.13 2.76.38 2.12-1.43 3.05-1.13 3.05-1.13.6 1.51.22 2.63.11 2.91.7.77 1.13 1.75 1.13 2.95 0 4.21-2.57 5.14-5.02 5.41.39.34.74 1.01.74 2.03v3.04c0 .29.2.64.76.53A11.1 11.1 0 0 0 12 .9Z" />
    )}
    {icon === "linkedin" && (
      <path d="M4.98 3.5a2.5 2.5 0 1 1 0 5 2.5 2.5 0 0 1 0-5ZM3 9.8h4v11.7H3V9.8Zm6.2 0h3.8v1.6h.06c.53-1 1.83-2.05 3.77-2.05 4.03 0 4.77 2.65 4.77 6.1v6.05h-4v-5.36c0-1.28-.02-2.93-1.78-2.93-1.79 0-2.06 1.4-2.06 2.84v5.45h-4V9.8Z" />
    )}
  </svg>
</a>
